# Telegram Summary Bot Environment Configuration

# Telegram MTProto (GramJS) - for listening to channels
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_STRING_SESSION=your_string_session_here

# Telegram Bot (Telegraf) - for sending summaries
TELEGRAM_BOT_TOKEN=your_bot_token_here

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Optional: Custom prompt for summarization
# Use {{period}} and {{messages}} placeholders
# OPENROUTER_CUSTOM_PROMPT=Please summarize these messages from {{period}}:\n\n{{messages}}

# Configuration
MONITORED_CHANNELS=@channel1,@channel2,-1001234567890
MONITORED_USERS=@user1,123456789
SUMMARY_CRON_EXPRESSION=0 */6 * * *
SUMMARY_DESTINATION=@summary_channel
AUTHORIZED_USERS=123456789,987654321

# Docker timezone
TZ=UTC
