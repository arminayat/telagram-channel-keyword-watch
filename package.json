{
  "name": "telegram-summary-bot",
  "version": "1.0.0",
  "description": "Telegram message summarization bot using GramJS and OpenRouter",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "auth": "ts-node src/auth/generate-session.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "telegram": "^2.19.4",
    "node-cron": "^3.0.3",
    "telegraf": "^4.15.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.4",
    "@types/node-cron": "^3.0.11",
    "ts-node": "^10.9.2",
